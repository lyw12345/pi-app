{
  "name": "@agegr/pi-web",
  "version": "0.6.13",
  "description": "Web UI for the pi coding agent",
  "license": "MIT",
  "bin": {
    "pi-web": "bin/pi-web.js"
  },
  "files": [
    "bin",
    ".next",
    "!.next/cache",
    "!.next/dev",
    "!.next/**/*.js.map",
    "public",
    "next.config.ts",
    "package.json"
  ],
  "scripts": {
    "dev": "PI_CODING_AGENT_DIR=~/tmp/pi-dev-agent NEXT_DIST_DIR=.next-dev-30142 next dev -p 30142 --webpack",
    "dev:prod": "echo 'WARNING: next dev on 30141 hot-reloads with source edits; use npm start for daily 30141.' >&2 && next dev -p 30141",
    "build": "next build --webpack",
    "start": "next start -p 30141",
    "lint": "eslint .",
    "test": "vitest",
    "test:run": "vitest run",
    "test:workbench": "node scripts/workbench-smoke.mjs",
    "test:m2": "node scripts/m2-preflight.mjs",
    "test:m3": "node scripts/m3-preflight.mjs",
    "test:m4": "node scripts/m4-preflight.mjs",
    "package:macos": "bash scripts/package-macos-app.sh",
    "tunnel:cloudflare": "bash scripts/tunnel-cloudflared.sh",
    "relay:server": "node --experimental-strip-types scripts/pi-relay-server.ts",
    "relay:host": "node --experimental-strip-types scripts/pi-relay-host.ts",
    "relay:client": "node --experimental-strip-types scripts/pi-relay-client.ts",
    "release": "npm version patch --no-git-tag-version && npm run build && npm publish --access public"
  },
  "dependencies": {
    "@earendil-works/pi-ai": "file:../pi/packages/ai",
    "@earendil-works/pi-coding-agent": "file:../pi/packages/coding-agent",
    "@lobehub/icons": "5.10.0",
    "@types/react-syntax-highlighter": "^15.5.13",
    "mammoth": "^1.12.0",
    "mermaid": "11.15.0",
    "next": "16.2.6",
    "pdfjs-dist": "4.10.38",
    "qrcode": "1.5.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^16.1.1",
    "remark-gfm": "^4.0.1",
    "web-push": "3.6.7"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^25",
    "@types/qrcode": "1.5.5",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "playwright": "^1.60.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.2.2",
    "typescript": "^5",
    "vitest": "^4.1.7"
  },
  "overrides": {
    "js-cookie": "3.0.8",
    "mermaid": "11.15.0",
    "postcss": "$postcss"
  }
}
