{
  "name": "pi-app",
  "version": "0.8.7",
  "description": "Web UI for the pi coding agent",
  "license": "MIT",
  "homepage": "https://github.com/asiachrispy/pi-app",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/asiachrispy/pi-app.git"
  },
  "bugs": {
    "url": "https://github.com/asiachrispy/pi-app/issues"
  },
  "bin": {
    "pi-app": "bin/pi-app.js"
  },
  "files": [
    "bin",
    "scripts/install-cli.mjs",
    "scripts/install-pi-cli-from-app.mjs",
    "scripts/uninstall-cli.mjs",
    "scripts/cli-link-common.mjs",
    ".next",
    "!.next/cache",
    "!.next/dev",
    "!.next/**/*.js.map",
    "public",
    "next.config.ts",
    "package.json"
  ],
  "scripts": {
    "dev": "PI_CODING_AGENT_DIR=~/tmp/pi-dev-agent NEXT_DIST_DIR=.next-dev-30142 next dev -p 30142",
    "dev:prod": "echo 'WARNING: next dev on 30141 hot-reloads with source edits; use npm start for daily 30141.' >&2 && next dev -p 30141",
    "build": "next build --webpack",
    "start": "next start -p 30141",
    "lint": "eslint .",
    "test": "vitest",
    "test:run": "vitest run",
    "test:workbench": "node scripts/workbench-smoke.mjs",
    "test:m2": "node scripts/m2-preflight.mjs",
    "test:m3": "node scripts/m3-preflight.mjs",
    "test:m4": "node scripts/m4-preflight.mjs",
    "postinstall": "node scripts/install-cli.mjs",
    "postuninstall": "node scripts/uninstall-cli.mjs",
    "package:macos": "bash scripts/package-macos-app.sh",
    "release:sync-pi": "bash scripts/sync-pi-upstream.sh",
    "release:sync-pi-deps": "bash scripts/sync-pi-deps.sh",
    "release:prepare": "bash scripts/release-pi-app.sh",
    "release:github": "bash scripts/github-release.sh",
    "release:version": "node scripts/release-version.mjs",
    "release:check": "node scripts/release-version.mjs --check",
    "tunnel:cloudflare": "bash scripts/tunnel-cloudflared.sh",
    "relay:server": "node --experimental-strip-types scripts/pi-relay-server.ts",
    "relay:host": "node --experimental-strip-types scripts/pi-relay-host.ts",
    "relay:client": "node --experimental-strip-types scripts/pi-relay-client.ts",
    "release": "npm version patch --no-git-tag-version && npm run build && npm publish --access public",
    "prepublishOnly": "node_modules/.bin/tsc --noEmit && node_modules/.bin/vitest run"
  },
  "dependencies": {
    "@earendil-works/pi-ai": "0.79.6",
    "@earendil-works/pi-coding-agent": "0.79.6",
    "@lobehub/icons": "5.10.0",
    "@types/react-syntax-highlighter": "15.5.13",
    "katex": "0.17.0",
    "mammoth": "1.12.0",
    "mermaid": "11.15.0",
    "next": "16.2.6",
    "pdfjs-dist": "4.10.38",
    "qrcode": "1.5.4",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-markdown": "10.1.0",
    "react-syntax-highlighter": "16.1.1",
    "rehype-katex": "7.0.1",
    "remark-gfm": "4.0.1",
    "remark-math": "6.0.0",
    "web-push": "3.6.7"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.3.0",
    "@testing-library/react": "16.3.2",
    "@types/node": "25.9.2",
    "@types/qrcode": "1.5.5",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "jsdom": "27.4.0",
    "playwright": "1.60.0",
    "postcss": "8.5.15",
    "tailwindcss": "4.3.0",
    "typescript": "5.9.3",
    "vitest": "4.1.8"
  },
  "overrides": {
    "js-cookie": "3.0.8",
    "mermaid": "11.15.0"
  }
}
